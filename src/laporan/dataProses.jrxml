	<subDataset name="dsAturan" uuid="cf5f80e3-a4b8-4bea-aa8c-136165ac18e2">
		<parameter name="ID_PROSES" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT aturan, support, confidence, keterangan
FROM detail_hasil_asosiasi
WHERE id_hasil_asosiasi = $P{ID_PROSES}
ORDER BY confidence DESC]]>
		</queryString>
		<field name="aturan" class="java.lang.String"/>
		<field name="support" class="java.lang.Double"/>
		<field name="confidence" class="java.lang.Double"/>
		<field name="keterangan" class="java.lang.String"/>
		<variable name="noRule" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$F{aturan}]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="dsPaket" uuid="7f4a2b1c-3e5d-4a9f-8b6c-2d1e9a0b4f3c">
		<parameter name="ID_PROSES" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT DISTINCT t.paket_items, t.total_harga
FROM (
	SELECT dha.id,
		(SELECT GROUP_CONCAT(dl.nama_layanan ORDER BY dl.nama_layanan SEPARATOR ' + ')
		 FROM datalayanan dl WHERE dha.aturan LIKE CONCAT('%', dl.nama_layanan, '%')) AS paket_items,
		(SELECT COALESCE(SUM(dl.harga),0)
		 FROM datalayanan dl WHERE dha.aturan LIKE CONCAT('%', dl.nama_layanan, '%')) AS total_harga
	FROM detail_hasil_asosiasi dha
	WHERE dha.id_hasil_asosiasi = $P{ID_PROSES}
) t
ORDER BY t.total_harga DESC]]>
		</queryString>
		<field name="paket_items" class="java.lang.String"/>
		<field name="total_harga" class="java.math.BigDecimal"/>
		<variable name="noPaket" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$F{paket_items}]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="LOGO" class="java.io.InputStream" isForPrompting="false"/>
	<parameter name="NAMA_ADMIN" class="java.lang.String">
		<defaultValueExpression><![CDATA["Admin"]]></defaultValueExpression>
	</parameter>
	<parameter name="TANGGAL_CETAK" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="ID_PROSES" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT id, tanggal_proses, mulai_tanggal, sampai_tanggal, min_support, min_confidence
FROM hasil_asosiasi
WHERE id = $P{ID_PROSES}]]>
	</queryString>
	<field name="id" class="java.lang.String"/>
	<field name="tanggal_proses" class="java.sql.Date"/>
	<field name="mulai_tanggal" class="java.sql.Date"/>
	<field name="sampai_tanggal" class="java.sql.Date"/>
	<field name="min_support" class="java.lang.Double"/>
	<field name="min_confidence" class="java.lang.Double"/>
