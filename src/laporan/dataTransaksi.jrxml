	<parameter name="TANGGAL_CETAK" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.util.Date()]]></defaultValueExpression>
	</parameter>
	<parameter name="TGL_AWAL" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.sql.Date(0L)]]></defaultValueExpression>
	</parameter>
	<parameter name="TGL_AKHIR" class="java.util.Date">
		<defaultValueExpression><![CDATA[new java.sql.Date(System.currentTimeMillis())]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT t.id_transaksi AS id_transaksi,
       t.tanggal AS tanggal,
       t.total_harga AS total_harga,
       d.nama_layanan AS nama_layanan,
       d.harga AS harga
FROM transaksi t
JOIN detail_transaksi d ON t.id_transaksi = d.id_transaksi
WHERE t.tanggal BETWEEN $P{TGL_AWAL} AND $P{TGL_AKHIR}
ORDER BY t.tanggal, t.id_transaksi]]>
	</queryString>
	<field name="id_transaksi" class="java.lang.String"/>
	<field name="tanggal" class="java.sql.Date"/>
	<field name="total_harga" class="java.lang.Long"/>
	<field name="nama_layanan" class="java.lang.String"/>
	<field name="harga" class="java.lang.Long"/>
